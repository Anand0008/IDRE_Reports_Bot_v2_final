{
  "version": "2.0",
  "description": "IDRE Reports Bot \u2014 Role-Based Access Control. Aligned with IDRE platform's actual 8 report access roles plus a full-access debug role.",
  "notes": {
    "system_tables_blocked_for_all": [
      "_prisma_migrations",
      "account",
      "admin_invitation",
      "bank_transaction",
      "invitation",
      "party_invitation",
      "session",
      "site_settings",
      "stripe_customer",
      "twoFactor",
      "user_restore_20260323094341",
      "verification"
    ],
    "user_table_note": "The user table is allowed for MA, PA, AM, and DQD roles for name/email lookup only. The SQL Writer prompt restricts which columns can be selected (name, email, role, id only \u2014 never password hashes or tokens).",
    "reasoning": "System/auth tables contain credential hashes, session tokens, and migration metadata. The user table is partially allowed for person-name lookups needed in assignment and performance reports."
  },
  "roles": {
